<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Organizer.Application.ViewModels.Components"
             x:Class="Organizer.Application.Components.SearchBar"
             x:DataType="vm:SearchBarViewModel">

    <UserControl.Styles>

        <Style Selector="TextBox.search-input">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12 10" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="TextBox.search-input:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="TextBox.search-input /template/ Border#PART_BorderElement">
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="Button.btn">
            <Setter Property="Height" Value="42" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="16 0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.btn-search">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#ffffff" />
        </Style>
        <Style Selector="Button.btn-search:pointerover">
            <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
        </Style>

        <Style Selector="Button.btn-register">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
            <Setter Property="Foreground" Value="#ffffff" />
        </Style>
        <Style Selector="Button.btn-register:pointerover">
            <Setter Property="Background" Value="{DynamicResource SuccessHoverBrush}" />
        </Style>

        <Style Selector="ComboBox.sort-picker">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12 0" />
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="ComboBox.sort-picker:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
        </Style>

    </UserControl.Styles>

    <Grid ColumnDefinitions="*,Auto,170"
          ColumnSpacing="10">
        <!-- Campo de busca -->
        <TextBox Grid.Column="0"
                 Classes="search-input"
                 Text="{Binding Query}"
                 PlaceholderText="{DynamicResource Loc.Search.Placeholder}" />

        <!-- Botão registrar -->
        <Button Grid.Column="1"
                Classes="btn btn-register"
                Command="{Binding RegisterCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="+" VerticalAlignment="Center" FontSize="16" />
                <TextBlock Text="{DynamicResource Loc.Search.Register}" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <!-- Ordenação -->
        <ComboBox Grid.Column="2"
                  Classes="sort-picker"
                  ItemsSource="{Binding SortOptions}"
                  SelectedItem="{Binding SelectedSort}" />

    </Grid>

</UserControl>

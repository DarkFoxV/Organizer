<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Organizer.Application.ViewModels"
             xmlns:cvm="using:Organizer.Application.ViewModels.Components"
             x:Class="Organizer.Application.Views.ManageTagsView"
             x:DataType="vm:ManageTagsViewModel">

    <UserControl.Styles>

        <Style Selector="TextBox.field">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12 8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="TextBox.field:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
        </Style>

        <Style Selector="ComboBox.color-picker">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12 0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinWidth" Value="130" />
        </Style>

        <Style Selector="Button.btn">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14 0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style Selector="Button.btn-ghost">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.btn-ghost:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentSoftTextBrush}" />
        </Style>

        <Style Selector="Border.floating-panel">
            <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FloatingBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BoxShadow" Value="0 18 50 #77000000" />
        </Style>

        <Style Selector="Border.tag-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceSoftAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18 14" />
            <Setter Property="BoxShadow" Value="0 10 28 #44000000" />
        </Style>
        <Style Selector="Border.tag-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BoxShadow" Value="0 16 36 #5A000000" />
        </Style>

    </UserControl.Styles>

    <Grid Background="{DynamicResource AppBackgroundBrush}">

        <Panel IsHitTestVisible="False">
            <Ellipse Width="560"
                     Height="560"
                     Fill="#163047"
                     Opacity="0.28"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-180 -220 0 0" />
            <Ellipse Width="420"
                     Height="420"
                     Fill="#153321"
                     Opacity="0.2"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0 0 -140 -160" />
        </Panel>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="28"
                        Spacing="16"
                        MaxWidth="1040"
                        HorizontalAlignment="Stretch">

                <!-- Header -->
                <Border Classes="floating-panel"
                        Padding="24 20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="{DynamicResource Loc.Tags.ManageTitle}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{DynamicResource Loc.Tags.ManageSubtitle}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </Border>

                <!-- Formulário de nova tag -->
                <Border Classes="floating-panel"
                        Padding="22 18">
                    <StackPanel Spacing="14">

                        <TextBlock Text="{DynamicResource Loc.Tags.New}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     Classes="field"
                                     Text="{Binding NewTagName}"
                                     PlaceholderText="{DynamicResource Loc.Tags.NamePlaceholder}" />

                            <ComboBox Grid.Column="1"
                                      Classes="color-picker"
                                      ItemsSource="{Binding ColorOptions}"
                                      SelectedItem="{Binding NewTagColor}" />

                            <Button Grid.Column="2"
                                    Classes="btn btn-success"
                                    Command="{Binding CreateTagCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="+" FontSize="16" VerticalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource Loc.Tags.Create}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Cabeçalho da lista -->
                <Border Classes="floating-panel"
                        Padding="18 12">
                    <Grid ColumnDefinitions="*,130,200" ColumnSpacing="20">
                        <TextBlock Grid.Column="0" Text="{DynamicResource Loc.Tags.ColumnName}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSubtleBrush}" />
                        <TextBlock Grid.Column="1" Text="{DynamicResource Loc.Tags.ColumnColor}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSubtleBrush}" />
                        <TextBlock Grid.Column="2" Text="{DynamicResource Loc.Tags.ColumnActions}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSubtleBrush}" />
                    </Grid>
                </Border>

                <!-- Lista de tags -->
                <ItemsControl ItemsSource="{Binding Tags}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="cvm:TagRowViewModel">

                            <Border Classes="tag-card"
                                    Margin="0 0 0 10">

                                <Grid ColumnDefinitions="*,130,200" ColumnSpacing="20">

                                    <!-- Nome -->
                                    <Panel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel IsVisible="{Binding IsNotEditing}"
                                                    Orientation="Horizontal" Spacing="10">
                                            <Border Width="12" Height="12"
                                                    CornerRadius="6"
                                                    Background="{Binding ColorHex}"
                                                    VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBox IsVisible="{Binding IsEditing}"
                                                 Classes="field"
                                                 Text="{Binding EditName}" />
                                    </Panel>

                                    <!-- Cor -->
                                    <Panel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock IsVisible="{Binding IsNotEditing}"
                                                   Text="{Binding Color}"
                                                   FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Center" />
                                        <ComboBox IsVisible="{Binding IsEditing}"
                                                  Classes="color-picker"
                                                  ItemsSource="{Binding $parent[UserControl].((vm:ManageTagsViewModel)DataContext).ColorOptions}"
                                                  SelectedItem="{Binding EditColor}" />
                                    </Panel>

                                    <!-- Ações -->
                                    <Panel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel IsVisible="{Binding IsNotEditing}"
                                                    Orientation="Horizontal" Spacing="8">
                                            <Button Classes="btn btn-primary"
                                                    Command="{Binding StartEditCommand}">
                                                <TextBlock Text="{DynamicResource Loc.Tags.Edit}" />
                                            </Button>
                                            <Button Classes="btn btn-danger"
                                                    Command="{Binding DeleteCommand}">
                                                <TextBlock Text="{DynamicResource Loc.Tags.Delete}" />
                                            </Button>
                                        </StackPanel>
                                        <StackPanel IsVisible="{Binding IsEditing}"
                                                    Orientation="Horizontal" Spacing="8">
                                            <Button Classes="btn btn-success"
                                                    Command="{Binding SaveCommand}">
                                                <TextBlock Text="{DynamicResource Loc.Tags.Save}" />
                                            </Button>
                                            <Button Classes="btn btn-ghost"
                                                    Command="{Binding CancelEditCommand}">
                                                <TextBlock Text="{DynamicResource Loc.Tags.Cancel}" />
                                            </Button>
                                        </StackPanel>
                                    </Panel>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>

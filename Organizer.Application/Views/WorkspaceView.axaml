<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Organizer.Application.ViewModels"
             xmlns:controls="using:Organizer.Application.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Organizer.Organizer.Application.Views.WorkspaceView"
             x:DataType="vm:WorkspaceViewModel">

    <UserControl.Styles>
        <Style Selector="Button.recent-workspace-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="10 8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="Center"
                                          Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.recent-workspace-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceSoftAltBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid x:Name="Viewport"
          Background="{Binding WorkspaceViewportBackground}"
          ClipToBounds="True"
          Focusable="True">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Abrir"
                          Click="OnOpenWorkspace" />
                <MenuItem Header="Salvar"
                          IsEnabled="{Binding HasImages}"
                          Click="OnSaveWorkspace" />
                <Separator />
                <MenuItem Header="Fechar workspace"
                          IsEnabled="{Binding HasImages}"
                          Click="OnCloseWorkspace" />
            </ContextMenu>
        </Grid.ContextMenu>

        <Border x:Name="BoardRoot"
                Width="{Binding BoardWidth}"
                Height="{Binding BoardHeight}"
                Background="{Binding WorkspaceBoardBackground}"
                BorderBrush="{Binding WorkspaceBoardBorderBrush}"
                BorderThickness="1"
                CornerRadius="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
            <controls:WorkspaceCanvas x:Name="WorkspaceSurface"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Focusable="True"
                                      Items="{Binding Items}" />
        </Border>

        <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="18"
                Background="{DynamicResource DangerSoftBrush}"
                BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12 10"
                ZIndex="10">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerSoftTextBrush}"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </Border>

        <Border IsVisible="{Binding ShowRecentWorkspaces}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Width="360"
                MaxWidth="520"
                Margin="24 0 24 64"
                Background="{DynamicResource SurfaceSoftBrush}"
                BorderBrush="{DynamicResource FloatingBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                ZIndex="5">
            <StackPanel Spacing="10">
                <TextBlock Text="{DynamicResource Loc.Workspace.RecentTitle}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />

                <ScrollViewer MaxHeight="240"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding RecentWorkspaces}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RecentWorkspaceItemViewModel">
                                <Button Classes="recent-workspace-button"
                                        Click="OnOpenRecentWorkspace">
                                    <Grid RowDefinitions="Auto,Auto">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding LastUsedText}"
                                                   IsVisible="{Binding HasLastUsedText}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <StackPanel IsVisible="{Binding IsEmpty}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsHitTestVisible="False">
            <TextBlock Text="{DynamicResource Loc.Workspace.EmptyTitle}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{DynamicResource Loc.Workspace.EmptySubtitle}"
                       FontSize="13"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="18"
                Background="{DynamicResource SurfaceSoftBrush}"
                BorderBrush="{DynamicResource FloatingBorderBrush}"
                BorderThickness="1"
                CornerRadius="999"
                Padding="10 6"
                IsHitTestVisible="False"
                ZIndex="10">
            <TextBlock x:Name="ZoomText"
                       Text="100%"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="12"
                       FontWeight="SemiBold" />
        </Border>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Organizer.Application.ViewModels"
             xmlns:components="using:Organizer.Application.Components"
             x:Class="Organizer.Application.Views.RegisterView"
             x:DataType="vm:RegisterViewModel">

    <UserControl.Styles>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="Border.section-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FloatingBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="BoxShadow" Value="0 18 50 #77000000" />
        </Style>

        <Style Selector="StackPanel.page-shell">
            <Setter Property="Margin" Value="28" />
            <Setter Property="Spacing" Value="16" />
            <Setter Property="MaxWidth" Value="1040" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Button.btn">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="20 0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style Selector="TextBox.field">
            <Setter Property="Padding" Value="12 10" />
            <Setter Property="FontSize" Value="14" />
        </Style>

    </UserControl.Styles>

    <Grid Background="{DynamicResource AppBackgroundBrush}"
          VerticalAlignment="Stretch"
          HorizontalAlignment="Stretch">

        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Classes="page-shell">

                <!-- Header -->
                <Border Classes="section-card">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <StackPanel Grid.Column="0"
                                    Spacing="4">
                            <TextBlock Text="{DynamicResource Loc.Register.Title}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock
                                Text="{DynamicResource Loc.Register.Subtitle}"
                                FontSize="13"
                                Foreground="{DynamicResource TextMutedBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="btn btn-danger"
                                Width="40" Height="40"
                                Padding="0"
                                VerticalAlignment="Top"
                                Command="{Binding CloseCommand}">
                            <TextBlock Text="✕" FontSize="16" FontWeight="Bold" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Seção: Selecionar imagens -->
                <Border Classes="section-card">

                    <StackPanel Spacing="16">

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Grid.Column="0"
                                        Spacing="4">
                                <TextBlock Classes="section-title"
                                           Text="{DynamicResource Loc.Register.Images}" />
                                <TextBlock
                                    Text="{DynamicResource Loc.Register.ImagesDescription}"
                                    FontSize="13"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Classes="btn btn-primary"
                                    x:Name="BtnPickImages"
                                    Click="OnPickImages"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">

                                    <TextBlock Text="🖼"
                                               VerticalAlignment="Center" />

                                    <TextBlock Text="{DynamicResource Loc.Register.SelectImages}"
                                               VerticalAlignment="Center" />

                                </StackPanel>

                            </Button>
                        </Grid>

                        <Grid>

                            <components:ImageOrderList
                                IsVisible="{Binding !ImageOrder.IsEmpty}"
                                x:Name="ImageOrderListControl" />

                            <Border IsVisible="{Binding ImageOrder.IsEmpty}"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushColor}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="28">

                                <StackPanel HorizontalAlignment="Center"
                                            Spacing="10">

                                    <TextBlock Text="🖼"
                                               FontSize="36"
                                               HorizontalAlignment="Center" />

                                    <TextBlock Text="{DynamicResource Loc.Register.NoImages}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" />

                                    <TextBlock Text="{DynamicResource Loc.Register.NoImagesHint}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSubtleBrush}"
                                               HorizontalAlignment="Center" />

                                </StackPanel>

                            </Border>

                        </Grid>

                    </StackPanel>

                </Border>

                <!-- Seção: Descrição -->
                <Border Classes="section-card">

                    <StackPanel Spacing="12">

                        <TextBlock Classes="section-title"
                                   Text="{DynamicResource Loc.Register.Description}" />
                        <TextBlock
                            Text="{DynamicResource Loc.Register.DescriptionHint}"
                            FontSize="13"
                            Foreground="{DynamicResource TextMutedBrush}"
                            TextWrapping="Wrap" />

                        <TextBox Classes="field"
                                 Text="{Binding Description}"
                                 PlaceholderText="{DynamicResource Loc.Register.DescriptionPlaceholder}" />

                    </StackPanel>

                </Border>

                <!-- Seção: Tags -->
                <Border Classes="section-card">

                    <StackPanel Spacing="12">

                        <TextBlock Classes="section-title"
                                   Text="{DynamicResource Loc.Register.Tags}" />
                        <TextBlock Text="{DynamicResource Loc.Register.TagsHint}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap" />

                        <TextBlock IsVisible="{Binding !TagsLoaded}"
                                   Text="{DynamicResource Loc.Register.LoadingTags}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}" />

                        <components:TagSelector
                            x:Name="TagSelectorControl"
                            IsVisible="{Binding TagsLoaded}" />

                    </StackPanel>

                </Border>

                <!-- Seção: Submit -->
                <Border Classes="section-card">

                    <StackPanel Spacing="18">

                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushColor}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14 12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">

                                <TextBlock IsVisible="{Binding StatusIsReady}"
                                           Text="✓"
                                           Foreground="{DynamicResource SuccessTextBrush}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />

                                <TextBlock IsVisible="{Binding !StatusIsReady}"
                                           Text="⚠"
                                           Foreground="{DynamicResource WarningTextBrush}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />

                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" />

                            </StackPanel>
                        </Border>

                        <!-- Erro -->
                        <Border
                            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="{DynamicResource DangerSoftBrush}"
                            BorderBrush="{DynamicResource DangerBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12 10">

                            <TextBlock Text="{Binding ErrorMessage}"
                                       FontSize="13"
                                       Foreground="{DynamicResource DangerSoftTextBrush}"
                                       TextWrapping="Wrap" />

                        </Border>

                        <Button Classes="btn btn-success"
                                IsEnabled="{Binding IsReady}"
                                Command="{Binding SubmitCommand}"
                                HorizontalAlignment="Left"
                                MinWidth="180">

                            <StackPanel Orientation="Horizontal"
                                        Spacing="10">

                                <TextBlock Text="💾"
                                           VerticalAlignment="Center" />

                                <TextBlock IsVisible="{Binding !IsSubmitting}"
                                           Text="{DynamicResource Loc.Register.Save}"
                                           VerticalAlignment="Center" />

                                <TextBlock IsVisible="{Binding IsSubmitting}"
                                           Text="{DynamicResource Loc.Register.Saving}"
                                           VerticalAlignment="Center" />

                            </StackPanel>

                        </Button>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Organizer.Application.ViewModels"
             x:Class="Organizer.Application.Views.GroupCopyPickerModal"
             x:DataType="vm:GroupCopyPickerViewModel">

    <UserControl.Styles>
        <Style Selector="Button.modal-btn">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.close-btn">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
            <Setter Property="Foreground" Value="#fff" />
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Button.copy-card">
            <Setter Property="Width" Value="246" />
            <Setter Property="MinHeight" Value="270" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#E6121824" />
            <Setter Property="BorderBrush" Value="#3A50677D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Stretch"
                                          Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.copy-card:pointerover">
            <Setter Property="BorderBrush" Value="#3b82f6" />
            <Setter Property="Background" Value="#F0161D2A" />
        </Style>
    </UserControl.Styles>

    <Grid IsVisible="{Binding IsVisible}">
        <Border Background="#D90A0F18" />

        <Panel IsHitTestVisible="False">
            <Ellipse Width="560"
                     Height="560"
                     Fill="#163047"
                     Opacity="0.32"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-190 -230 0 0" />
            <Ellipse Width="460"
                     Height="460"
                     Fill="#153321"
                     Opacity="0.22"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0 0 -160 -170" />
        </Panel>

        <Grid HorizontalAlignment="Center" RowDefinitions="Auto,*"
              Margin="28">
            <Border Grid.Row="0"
                    Background="#E6121824"
                    BorderBrush="#3A50677D"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="22 18"
                    Margin="0 0 0 16"
                    BoxShadow="0 18 50 #77000000">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CountText}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Classes="modal-btn close-btn"
                            Command="{Binding CloseCommand}">
                        <TextBlock Text="✕" FontSize="16" FontWeight="Bold" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:GroupCopyPickerItemViewModel">
                            <Button Classes="copy-card"
                                    Click="OnCopyImage"
                                    Margin="0 0 14 14">
                                <Grid RowDefinitions="170,Auto,*">
                                    <Border Grid.Row="0"
                                            Background="#220b1018"
                                            CornerRadius="18 18 0 0"
                                            Padding="10">
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   IsVisible="{Binding HasThumbnail}" />
                                            <TextBlock Text="Sem preview"
                                                       IsVisible="{Binding !HasThumbnail}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="Auto,*"
                                          Margin="14 12 14 0"
                                          ColumnSpacing="10">
                                        <Border Grid.Column="0"
                                                Background="#263b82f6"
                                                CornerRadius="99"
                                                Padding="8 3"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding NumberText}"
                                                       Foreground="#93c5fd"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Filename}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>

                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Caption}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxLines="3"
                                               Margin="14 8 14 14" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
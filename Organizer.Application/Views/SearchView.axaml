<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Organizer.Application.ViewModels"
             xmlns:cvm="using:Organizer.Application.ViewModels.Components"
             xmlns:components="using:Organizer.Application.Components"
             xmlns:views="using:Organizer.Application.Views"
             x:Class="Organizer.Application.Views.SearchView"
             x:DataType="vm:SearchViewModel">

    <UserControl.Styles>
        <Style Selector="Border.floating-panel">
            <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FloatingBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BoxShadow" Value="0 18 50 #77000000" />
        </Style>

        <Style Selector="Border.search-shell">
            <Setter Property="Padding" Value="14" />
            <Setter Property="MaxWidth" Value="1080" />
        </Style>

        <Style Selector="Border.tags-shell">
            <Setter Property="Padding" Value="18 14 18 10" />
            <Setter Property="MaxWidth" Value="1080" />
        </Style>

        <Style Selector="Border.pagination-shell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
            <Setter Property="Padding" Value="10 0" />
            <Setter Property="MaxWidth" Value="760" />
        </Style>

        <Style Selector="Button.confirm-action">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="18 0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.confirm-cancel">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="Button.confirm-cancel:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid Background="{DynamicResource AppBackgroundBrush}">

        <Panel IsHitTestVisible="False">
            <Ellipse Width="520"
                     Height="520"
                     Fill="#182A3F"
                     Opacity="0.28"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-160 -210 0 0" />
            <Ellipse Width="440"
                     Height="440"
                     Fill="#123528"
                     Opacity="0.18"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0 0 -130 -170" />
        </Panel>

        <Grid>

            <StackPanel IsVisible="{Binding IsLoading}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" />
                <TextBlock Text="{DynamicResource Loc.Common.Loading}"
                           FontSize="14"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel IsVisible="{Binding IsEmpty}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Margin="0 76 0 0">
                <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="{DynamicResource Loc.Search.EmptyTitle}"
                           FontSize="16"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{DynamicResource Loc.Search.EmptySubtitle}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSubtleBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <Border Padding="20 184 20 92">
                <ScrollViewer IsVisible="{Binding !IsEmpty}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">

                    <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding Cards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="cvm:CardItemViewModel">
                                <components:ImageContainer DataContext="{Binding}" Margin="8" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>
            </Border>

        </Grid>

        <StackPanel ZIndex="20"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Margin="24 18"
                    Spacing="10">

            <Border Classes="floating-panel search-shell"
                    HorizontalAlignment="Stretch">
                <components:SearchBar
                    DataContext="{Binding SearchBar}" />
            </Border>

            <Border Classes="floating-panel tags-shell"
                    HorizontalAlignment="Stretch">
                <components:TagSelector
                    DataContext="{Binding TagSelector}" />
            </Border>

        </StackPanel>

        <Border ZIndex="20"
                Classes="floating-panel pagination-shell"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="24 0 24 18">

            <components:Pagination
                DataContext="{Binding Pagination}"
                HorizontalAlignment="Center" />

        </Border>

        <components:ImagePreviewModal
            ZIndex="100"
            DataContext="{Binding Preview}" />

        <views:GroupCopyPickerModal
            ZIndex="100"
            DataContext="{Binding CopyPicker}" />

        <Border ZIndex="140"
                IsVisible="{Binding IsDeleteConfirmationVisible}"
                Background="{DynamicResource OverlayBrush}">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="430"
                        Background="{DynamicResource OverlayCardBrush}"
                        BorderBrush="{DynamicResource FloatingBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="22"
                        BoxShadow="0 24 60 #99000000">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding DeleteConfirmationTitle}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding DeleteConfirmationMessage}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Background="{DynamicResource DangerSoftBrush}"
                                BorderBrush="{DynamicResource DangerBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12 10">
                            <TextBlock Text="{DynamicResource Loc.Search.DeleteWarning}"
                                       Foreground="{DynamicResource DangerSoftTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="10">
                            <Button Classes="confirm-action confirm-cancel"
                                    Command="{Binding CancelDeleteCommand}">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{DynamicResource Loc.Common.Cancel}" />
                            </Button>
                            <Button Classes="confirm-action btn btn-danger"
                                    Command="{Binding ConfirmDeleteCommand}">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{DynamicResource Loc.Common.Delete}" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>

</UserControl>

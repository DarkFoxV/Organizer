<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Organizer.Application.ViewModels.Components"
             x:Class="Organizer.Application.Components.ImageContainer"
             x:DataType="vm:CardItemViewModel"
             Width="220">

  <UserControl.Styles>

    <Style Selector="Button.action-btn">
      <Setter Property="Height" Value="38"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              Content="{TemplateBinding Content}"/>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="Button.btn-view">
      <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
      <Setter Property="Foreground" Value="#fff"/>
    </Style>
    <Style Selector="Button.btn-view:pointerover">
      <Setter Property="Background" Value="{DynamicResource SuccessHoverBrush}"/>
    </Style>

    <Style Selector="Button.btn-edit">
      <Setter Property="Background" Value="#d97706"/>
      <Setter Property="Foreground" Value="#fff"/>
    </Style>
    <Style Selector="Button.btn-edit:pointerover">
      <Setter Property="Background" Value="#b45309"/>
    </Style>

    <Style Selector="Button.btn-delete">
      <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
      <Setter Property="Foreground" Value="#fff"/>
    </Style>
    <Style Selector="Button.btn-delete:pointerover">
      <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
    </Style>

  </UserControl.Styles>

  <Border Background="{DynamicResource SurfaceBrush}"
          BorderBrush="{DynamicResource BorderBrushColor}"
          BorderThickness="1"
          CornerRadius="12"
          ClipToBounds="True">

    <DockPanel>

      <!-- Thumbnail -->
      <Grid DockPanel.Dock="Top" Height="180">

        <Border Padding="8">
          <Image Source="{Binding Thumbnail}"
                 Stretch="Uniform"
                 IsVisible="{Binding IsLoaded}"/>
        </Border>

        <Border IsVisible="{Binding !IsLoaded}"
                Background="{DynamicResource SurfaceAltBrush}">
          <TextBlock Text="⏳"
                     FontSize="28"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <Border IsVisible="{Binding IsGroup}"
                Background="#CC000000"
                CornerRadius="99"
                Padding="6 3"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0 8 8 0">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="⧉" Foreground="#fff" FontSize="11"/>
            <TextBlock Text="{Binding ImageCount}"
                       Foreground="#fff"
                       FontSize="11"
                       FontWeight="SemiBold"/>
          </StackPanel>
        </Border>

      </Grid>

      <!-- Botões -->
      <Grid DockPanel.Dock="Bottom"
            ColumnDefinitions="*,6,*,6,*,6,*"
            Margin="10 8 10 10">

        <Button Grid.Column="0"
                Classes="action-btn btn-delete"
                Command="{Binding DeleteCommand}"
                ToolTip.Tip="Deletar">
          <TextBlock Text="🗑 Del" FontSize="12"/>
        </Button>

        <Button Grid.Column="2"
                Classes="action-btn btn-view"
                Command="{Binding ViewCommand}"
                ToolTip.Tip="Visualizar">
          <TextBlock Text="👁 Ver" FontSize="12"/>
        </Button>

        <Button Grid.Column="4"
                Classes="action-btn btn-view"
                Click="OnCopyImage"
                ToolTip.Tip="Copiar imagem">
          <TextBlock Text="⎘ Cop" FontSize="12"/>
        </Button>

        <Button Grid.Column="6"
                Classes="action-btn btn-edit"
                Command="{Binding EditCommand}"
                ToolTip.Tip="Editar">
          <TextBlock Text="✏ Edit" FontSize="12"/>
        </Button>

      </Grid>

      <!-- Data -->
      <TextBlock DockPanel.Dock="Bottom"
                 Text="{Binding CreatedAt}"
                 FontSize="11"
                 Foreground="{DynamicResource TextSubtleBrush}"
                 HorizontalAlignment="Center"
                 Margin="0 0 0 4"/>

      <!-- Descrição -->
      <ScrollViewer DockPanel.Dock="Bottom"
                    Height="80"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <TextBlock Text="{Binding Description}"
                   FontSize="13"
                   Foreground="{DynamicResource TextMutedBrush}"
                   TextWrapping="Wrap"
                   Margin="12 8"/>
      </ScrollViewer>

    </DockPanel>

  </Border>

</UserControl>
